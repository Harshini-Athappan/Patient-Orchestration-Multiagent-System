# ─────────────────────────────────────────────────────────────
# Python cache
# ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ─────────────────────────────────────────────────────────────
# Virtual environments
# ─────────────────────────────────────────────────────────────
.env
.env.local
.venv/
venv/
env/
ENV/

# ─────────────────────────────────────────────────────────────
# Secrets — NEVER push these
# ─────────────────────────────────────────────────────────────
*.env
secrets.json
credentials.json

# ─────────────────────────────────────────────────────────────
# Database / Persistent state
# ─────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
orchestrator.db

# ─────────────────────────────────────────────────────────────
# Testing
# ─────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
*.xml

# ─────────────────────────────────────────────────────────────
# IDE / Editor
# ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ─────────────────────────────────────────────────────────────
# Streamlit
# ─────────────────────────────────────────────────────────────
.streamlit/

# ─────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────
*.log
logs/

# ─────────────────────────────────────────────────────────────
